{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && CI=false GENERATE_SOURCEMAP=false npm run build"
  },
  "deploy": {
    "startCommand": "npx serve@14 -s build -l $PORT",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
